---
// Hero.astro — Full-width hero: photo left, bold text right
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="section hero" data-theme="light" id="hero">
  <canvas id="particle-canvas" class="particle-canvas"></canvas>
  <div class="hero-inner">
    <div class="hero-image">
      <img
        src={`${base}/images/hero.jpg`}
        alt="Eric So presenting"
        loading="eager"
      />
    </div>
    <div class="hero-text">
      <h1 class="hero-name">Eric So</h1>
      <p class="hero-title">MIT Professor of Global Economics and Behavioral Science</p>
    </div>
  </div>
</section>

<script is:inline data-astro-rerun>
  // Scroll-linked hero fade — as the user scrolls past the hero, its
  // contents fade and lift slightly so the bio reveals cleanly underneath.
  // The particle canvas (particles.js) reads the same --hero-progress var
  // to dial its intensity in sync.
  (function () {
    const hero = document.getElementById('hero');
    if (!hero) return;

    let ticking = false;

    function update() {
      const rect = hero.getBoundingClientRect();
      const h = rect.height || 1;
      // 0 at the top of the hero, 1 once scrolled a full hero-height down.
      const raw = Math.min(1, Math.max(0, -rect.top / h));
      document.documentElement.style.setProperty('--hero-progress', raw.toFixed(3));
      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }

    update();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', update, { passive: true });
  })();
</script>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 70vh;
    padding-top: 5rem; /* clear navbar */
    padding-bottom: 4rem;
    overflow: hidden;
  }

  .particle-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 38% 1fr;
    gap: clamp(2rem, 3vw, 4rem);
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    /* Scroll-linked fade + gentle lift. --hero-progress is 0..1, set by
       the inline script above. */
    opacity: calc(1 - var(--hero-progress, 0) * 0.85);
    transform: translateY(calc(var(--hero-progress, 0) * -32px));
    transition: opacity 0.05s linear, transform 0.05s linear;
    will-change: opacity, transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-inner {
      opacity: 1;
      transform: none;
    }
  }

  .hero-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
    filter: grayscale(100%);
  }

  .hero-text {
    padding-right: 1rem;
  }

  .hero-name {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 0.95;
    margin-bottom: 1rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.2vw, 3rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.05;
    color: var(--gray-400);
    max-width: none;
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero-text {
      padding: 0;
      text-align: left;
    }

    .hero-name {
      font-size: clamp(2rem, 8vw, 3rem);
    }
  }
</style>
