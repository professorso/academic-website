---
// Hero.astro — Full-width hero: photo left, bold text right
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="section hero" data-theme="light" id="hero">
  <canvas id="particle-canvas" class="particle-canvas"></canvas>
  <div class="hero-inner">
    <div class="hero-image">
      <img
        src={`${base}/images/hero.jpg`}
        alt="Eric So presenting"
        loading="eager"
      />
    </div>
    <div class="hero-text">
      <h1 class="hero-name">Eric So</h1>
      <p class="hero-title">MIT Professor of Global Economics and Behavioral Science</p>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 70vh;
    padding-top: 5rem; /* clear navbar */
    padding-bottom: 4rem;
    overflow: hidden;
  }

  .particle-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 38% 1fr;
    gap: clamp(2rem, 3vw, 4rem);
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
  }

  .hero-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
    filter: grayscale(100%);
  }

  .hero-text {
    padding-right: 1rem;
  }

  .hero-name {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 0.95;
    margin-bottom: 1rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.2vw, 3rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.05;
    color: var(--gray-400);
    max-width: none;
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero-text {
      padding: 0;
      text-align: left;
    }

    .hero-name {
      font-size: clamp(2rem, 8vw, 3rem);
    }
  }
</style>
