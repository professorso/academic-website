---
// ResearchGroup.astro — Placeholder for group members
---

<section class="section" data-theme="dark" id="research-group">
  <div class="section-inner">
    <span class="section-label">Group</span>
    <h2 class="section-title">Research Group</h2>
    <p class="group-description">
      The AI, Finance &amp; Decisions group at MIT IDE investigates how artificial
      intelligence reshapes financial markets, corporate behavior, and economic
      policy.
    </p>
    <a href="https://ide.mit.edu/research-group/ai-finance-decisions/" class="link-arrow" target="_blank" rel="noopener">
      Visit MIT IDE Page
    </a>
    <p class="group-note">Group members and current projects coming soon.</p>
  </div>
</section>

<style>
  .group-description {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--gray-200);
    max-width: 60ch;
    margin-bottom: 1.5rem;
  }

  .group-note {
    margin-top: 2rem;
    font-size: 0.85rem;
    color: var(--gray-400);
    font-style: italic;
  }

  .link-arrow {
    color: var(--gray-400);
  }
</style>
