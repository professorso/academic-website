---
// RolesSection.astro — Leadership roles & affiliations
---

<section class="section" data-theme="light" id="roles">
  <div class="section-inner">
    <span class="section-label">Leadership &amp; Affiliations</span>
    <div class="roles-list">
      <a href="https://executive.mit.edu/course/ai-executive-academy/a05U1000002o7uoIAA.html" class="role-card" target="_blank" rel="noopener">
        <span class="role-title">Faculty Co-Director</span>
        <span class="role-org">AI Executive Academy</span>
        <span class="role-arrow">→</span>
      </a>
      <a href="https://mitsloanedtech.mit.edu/ai/" class="role-card" target="_blank" rel="noopener">
        <span class="role-title">Lead Faculty</span>
        <span class="role-org">MIT Sloan Generative AI Hub for Teaching and Learning</span>
        <span class="role-arrow">→</span>
      </a>
      <a href="https://ide.mit.edu/research-group/ai-finance-decisions/" class="role-card" target="_blank" rel="noopener">
        <span class="role-title">Research Group Lead</span>
        <span class="role-org">AI, Finance &amp; Decisions Group — MIT IDE</span>
        <span class="role-arrow">→</span>
      </a>
      <a href="https://mitsloan.mit.edu/programs/phd/explore-program" class="role-card" target="_blank" rel="noopener">
        <span class="role-title">Faculty Chair</span>
        <span class="role-org">MIT Sloan PhD Program</span>
        <span class="role-arrow">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .roles-list {
    display: grid;
    gap: 0;
  }

  .role-card {
    display: grid;
    grid-template-columns: 200px 1fr auto;
    align-items: center;
    gap: 2rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--gray-200);
    transition: padding-left 0.2s ease;
  }

  a.role-card:hover {
    padding-left: 1rem;
    opacity: 1;
  }

  .role-card:first-child {
    border-top: 1px solid var(--gray-200);
  }

  .role-title {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gray-400);
  }

  .role-org {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    text-transform: uppercase;
  }

  .role-arrow {
    font-size: 1.2rem;
    opacity: 0;
    transition: opacity 0.2s;
  }

  a.role-card:hover .role-arrow {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .role-card {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }

    .role-arrow {
      display: none;
    }
  }
</style>
