---
// ExternalLinks.astro — Academic profile links
const links = [
  {
    label: 'SSRN',
    url: 'http://papers.ssrn.com/sol3/cf_dev/AbsByAuth.cfm?per_id=1431328',
    description: 'Working papers and publications',
  },
  {
    label: 'Google Scholar',
    url: 'https://scholar.google.com/citations?user=HuqQLucAAAAJ&hl=en',
    description: 'Citation profile and metrics',
  },
{
    label: 'MIT IDE',
    url: 'https://ide.mit.edu/research-group/ai-finance-decisions/',
    description: 'AI, Finance & Decisions group',
  },
];
---

<section class="section" data-theme="dark" id="links">
  <div class="section-inner">
    <span class="section-label">Elsewhere</span>
    <div class="links-grid">
      {links.map((link) => (
        <a href={link.url} class="ext-link" target="_blank" rel="noopener">
          <span class="ext-label">{link.label}</span>
          <span class="ext-desc">{link.description}</span>
          <span class="ext-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .links-grid {
    display: grid;
    gap: 0;
  }

  .ext-link {
    display: grid;
    grid-template-columns: 180px 1fr auto;
    align-items: center;
    gap: 2rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--gray-800);
    transition: padding-left 0.2s ease;
  }

  .ext-link:first-child {
    border-top: 1px solid var(--gray-800);
  }

  .ext-link:hover {
    padding-left: 1rem;
    opacity: 1;
  }

  .ext-label {
    font-family: var(--font-display);
    font-size: 1.4rem;
    text-transform: uppercase;
  }

  .ext-desc {
    font-size: 0.85rem;
    color: var(--gray-600);
  }

  .ext-arrow {
    font-size: 1.2rem;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .ext-link:hover .ext-arrow {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .ext-link {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }

    .ext-arrow {
      display: none;
    }
  }
</style>
