---
// NewsFeed.astro — Recent LinkedIn posts grid
const posts = [
  {
    title: 'Building a Live Stock Screener with Claude Code',
    snippet: 'In my AI & Robotics class at MIT Sloan, I teach students to pursue the "Previously Impossible." To demonstrate, I built a live, interactive stock screener from scratch in just a few hours.',
    link: 'https://www.linkedin.com/posts/eric-so-87531768_in-my-ai-robotics-class-at-mit-sloan-i-activity-7424538385664458754-BzY_',
  },
  {
    title: 'OpenAI\'s Prism: A Game-Changer for Technical Teaching',
    snippet: 'Two sentences. That\'s all it took to generate a clear, well-organized document with a solid explanation and proof for a theorem I teach at MIT. The math was sound, the layout was polished.',
    link: 'https://www.linkedin.com/posts/eric-so-87531768_ive-been-testing-openais-new-tool-prism-activity-7422281787902611456-3OjF',
  },
  {
    title: 'ChatGPT vs. Google Search on Learning Outcomes',
    snippet: 'LLMs deliver pre-packaged information, making learning passive. Web search requires active navigation, source evaluation, and synthesis \u2014 processes that produce deeper understanding.',
    link: 'https://www.linkedin.com/posts/eric-so-87531768_ai-learning-education-activity-7344084848732504064-MS-j',
  },
  {
    title: 'Your Brain on AI',
    snippet: '83% of ChatGPT users couldn\'t quote their own essays minutes later, vs. near-perfect recall without AI. One of the first studies to measure how ChatGPT use affects neural activity.',
    link: 'https://www.linkedin.com/posts/eric-so-87531768_your-brain-on-ai-one-of-the-first-studies-activity-7341083502219591682-Uai0',
  },
];
---

<section class="section" data-theme="light" id="news">
  <div class="section-inner">
    <span class="section-label">LinkedIn</span>
    <h2 class="section-title">Featured Posts</h2>

    <div class="posts-grid">
      {posts.map((post) => (
        <a href={post.link} class="card post-card" target="_blank" rel="noopener">
          <h3 class="card-title">{post.title}</h3>
          <p class="card-body">{post.snippet}</p>
          <span class="link-arrow">Read on LinkedIn &rarr;</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    border: 1px solid var(--gray-200);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  a.post-card:hover {
    border-color: var(--black);
    transform: translateY(-4px);
    opacity: 1;
  }

  .post-card .card-title {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0;
    line-height: 1.35;
    margin-bottom: 0.75rem;
  }

  .post-card .card-body {
    color: var(--gray-600);
    font-size: 0.85rem;
    line-height: 1.6;
    flex: 1;
    margin-bottom: 1.25rem;
  }

  .post-card .link-arrow {
    color: var(--gray-400);
    font-size: 0.8rem;
    transition: color 0.2s ease;
  }

  a.post-card:hover .link-arrow {
    color: var(--black);
  }

  @media (max-width: 768px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
