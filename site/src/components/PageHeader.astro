---
// PageHeader.astro — Subpage header with background photo
interface Props {
  label: string;
  title: string;
  image: string;
}

const { label, title, image } = Astro.props;
---

<section class="page-header" data-theme="dark">
  <div class="page-header-bg" style={`background-image: url(${image})`}></div>
  <div class="page-header-overlay"></div>
  <div class="section-inner page-header-content">
    <span class="section-label">{label}</span>
    <h1 class="page-title">{title}</h1>
  </div>
</section>

<style>
  .page-header {
    position: relative;
    padding: 10rem var(--section-pad-x) 4rem;
    overflow: hidden;
  }

  .page-header-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 30%;
    filter: grayscale(100%);
  }

  .page-header-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 10, 10, 0.7) 0%,
      rgba(10, 10, 10, 0.85) 100%
    );
  }

  .page-header-content {
    position: relative;
    z-index: 1;
  }

  .page-title {
    font-size: clamp(3rem, 6vw, 5rem);
    color: var(--white);
  }

  .section-label {
    color: var(--gray-400);
  }
</style>
