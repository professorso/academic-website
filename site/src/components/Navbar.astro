---
// Navbar.astro — Fixed top navigation bar
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<nav class="navbar" id="navbar" aria-label="Main navigation">
  <div class="navbar-inner">
    <div class="navbar-menu-wrap">
      <button class="navbar-menu-btn" id="menu-btn" aria-label="Open site menu" aria-expanded="false">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <span class="menu-btn-label">MENU</span>
      </button>
      <ul class="site-dropdown" id="site-dropdown">
        <li><a href={`${base}/`}>HOME</a></li>
        <li><a href={`${base}/research/`}>RESEARCH</a></li>
        <li class="sub-link"><a href={`${base}/working-papers/`}>Working Papers</a></li>
        <li><a href={`${base}/media/`}>MEDIA + VIDEOS</a></li>
        <li><a href={`${base}/the-collision/`}>THE COLLISION</a></li>
        <li><a href={`${base}/data/`}>DATA + ARTIFACTS</a></li>
      </ul>
    </div>

    <button class="navbar-toggle" id="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <ul class="navbar-links" id="nav-links">
      <li><a href={`${base}/`}>HOME</a></li>
      <li class="has-dropdown">
        <a href={`${base}/research/`}>RESEARCH</a>
        <ul class="dropdown">
          <li><a href={`${base}/working-papers/`}>Working Papers</a></li>
        </ul>
      </li>
      <li><a href={`${base}/media/`}>MEDIA + VIDEOS</a></li>
      <li><a href={`${base}/the-collision/`}>THE COLLISION</a></li>
      <li><a href={`${base}/data/`}>DATA + ARTIFACTS</a></li>
    </ul>

    <div class="navbar-right">
      <button class="navbar-icon-btn navbar-search-btn" id="navbar-search-btn" aria-label="Open site search (⌘K)">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <span class="icon-btn-label search-kbd">⌘K</span>
      </button>
      <a href="https://www.linkedin.com/in/eric-so-87531768/" class="navbar-icon-btn" target="_blank" rel="noopener" aria-label="Follow on LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        <span class="icon-btn-label">FOLLOW</span>
      </a>
      <a href={`${base}/files/CV_EricSo.pdf`} class="navbar-icon-btn" target="_blank" rel="noopener" aria-label="Download CV">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="12" y1="18" x2="12" y2="12"/>
          <polyline points="9 15 12 18 15 15"/>
        </svg>
        <span class="icon-btn-label">CV</span>
      </a>
      <button class="navbar-contact" id="contact-btn" aria-label="Open contact information">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        <span class="contact-label">CONTACT</span>
      </button>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    background: var(--black);
    color: var(--white);
    transition: background-color 0.4s ease, color 0.4s ease;
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1400px;
    margin: 0 auto;
    padding: 1rem 2rem;
  }

  /* Site menu button (top-left) */
  .navbar-menu-wrap {
    position: relative;
  }

  .navbar-menu-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--white);
    padding: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    transition: opacity 0.2s;
  }

  .navbar-menu-btn:hover {
    opacity: 0.6;
  }

  .site-dropdown {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    background: var(--black);
    border: 1px solid rgba(255, 255, 255, 0.15);
    padding: 0.75rem 0;
    min-width: 220px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    transition: all 0.2s ease;
    z-index: 200;
  }

  .site-dropdown.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .site-dropdown li a {
    display: block;
    padding: 0.6rem 1.5rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--white);
    transition: background-color 0.15s;
  }

  .site-dropdown li a:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .site-dropdown li.sub-link a {
    padding-left: 2.5rem;
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--gray-400);
  }

  .navbar-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    flex-shrink: 1;
    overflow: hidden;
  }

  .navbar-links li {
    white-space: nowrap;
    flex-shrink: 0;
  }

  .navbar-links a {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    transition: opacity 0.2s;
  }

  .navbar-links a:hover {
    opacity: 0.6;
  }

  /* Dropdown */
  .has-dropdown {
    position: relative;
  }

  .dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--black);
    padding: 0.75rem 0;
    min-width: 180px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    transition: all 0.2s ease;
  }

  .has-dropdown:hover .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown a {
    display: block;
    padding: 0.5rem 1.25rem;
    font-size: 0.7rem;
    white-space: nowrap;
  }

  /* Right-side group — must always stay visible */
  .navbar-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  /* Icon buttons (LinkedIn, CV) */
  .navbar-icon-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--white);
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    transition: background-color 0.2s, border-color 0.2s;
  }

  .navbar-icon-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.6);
    opacity: 1;
  }

  .search-kbd {
    font-family: var(--font-body);
    letter-spacing: 0;
  }

  /* Contact button */
  .navbar-contact {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--white);
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    transition: background-color 0.2s, border-color 0.2s;
  }

  .navbar-contact:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.6);
  }

  /* Hamburger */
  .navbar-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
    color: var(--white);
  }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 2px;
    background: currentColor;
    transition: transform 0.3s, opacity 0.3s;
  }

  /* Mobile */
  @media (max-width: 1200px) {
    .search-kbd {
      display: none;
    }

    .navbar-search-btn {
      padding: 0.5rem;
      border: none;
    }
  }

  @media (max-width: 900px) {
    .navbar-toggle {
      display: flex;
    }

    .navbar-links {
      position: fixed;
      top: 0;
      right: -100%;
      width: 280px;
      height: 100vh;
      flex-direction: column;
      background: var(--black);
      padding: 5rem 2rem 2rem;
      gap: 1.5rem;
      align-items: flex-start;
      transition: right 0.3s ease;
    }

    .navbar-links.open {
      right: 0;
    }

    .dropdown {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      padding: 0.5rem 0 0 1rem;
    }

    .contact-label,
    .icon-btn-label,
    .menu-btn-label {
      display: none;
    }

    .navbar-icon-btn,
    .navbar-contact {
      border: none;
      padding: 0.5rem;
    }
  }

  /* Light-mode navbar (when over light sections) */
  :global(.navbar--on-light) .navbar-menu-btn {
    color: var(--black);
  }

  :global(.navbar--on-light) .navbar-icon-btn,
  :global(.navbar--on-light) .navbar-contact {
    color: var(--black);
    border-color: rgba(0, 0, 0, 0.3);
  }

  :global(.navbar--on-light) .navbar-icon-btn:hover,
  :global(.navbar--on-light) .navbar-contact:hover {
    background: rgba(0, 0, 0, 0.05);
    border-color: rgba(0, 0, 0, 0.6);
  }

  :global(.navbar--on-light) .site-dropdown {
    background: var(--white);
    border-color: rgba(0, 0, 0, 0.15);
  }

  :global(.navbar--on-light) .site-dropdown li a {
    color: var(--black);
  }

  :global(.navbar--on-light) .site-dropdown li a:hover {
    background: rgba(0, 0, 0, 0.05);
  }
</style>

<script>
  // Re-binds all navbar handlers. Called on initial load and after every
  // view transition, since the <body> is swapped and element references
  // from the prior page no longer exist.
  function setupNavbar() {
    const menuBtn = document.getElementById('menu-btn');
    const siteDropdown = document.getElementById('site-dropdown');

    menuBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = siteDropdown?.classList.toggle('open');
      menuBtn.setAttribute('aria-expanded', String(isOpen));
    });

    siteDropdown?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        siteDropdown.classList.remove('open');
        menuBtn?.setAttribute('aria-expanded', 'false');
      });
    });

    const toggle = document.getElementById('nav-toggle');
    const links = document.getElementById('nav-links');

    toggle?.addEventListener('click', () => {
      const isOpen = links?.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });

    links?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        links.classList.remove('open');
        toggle?.setAttribute('aria-expanded', 'false');
      });
    });

    const searchBtn = document.getElementById('navbar-search-btn');
    searchBtn?.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('cmdk:open'));
    });
  }

  // Document-level outside-click handler. Install once so navigating
  // between pages doesn't stack duplicate listeners.
  if (!window.__navOutsideClickInstalled) {
    document.addEventListener('click', () => {
      const sd = document.getElementById('site-dropdown');
      const mb = document.getElementById('menu-btn');
      sd?.classList.remove('open');
      mb?.setAttribute('aria-expanded', 'false');
    });
    window.__navOutsideClickInstalled = true;
  }

  setupNavbar();
  document.addEventListener('astro:page-load', setupNavbar);
</script>
