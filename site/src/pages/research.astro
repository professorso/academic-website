---

<BaseLayout title="Research — Eric So" description="Published research by Eric So spanning behavioral finance, asset pricing, AI, and regulatory policy.">
  <PageHeader label="Research" title="Publications" image="/images/backdrops/Sloan2.jpeg" />

  <FeaturedResearch />

  {categories.map((cat) => (
    <section class="section" data-theme="light">
      <div class="section-inner">
        <h2 class="category-title">{cat.name}</h2>
        <div class="papers-list">
          {cat.papers.map((paper) => (
            <article class="paper-item">
              {paper.link ? (
                <a href={paper.link} class="paper-link" target="_blank" rel="noopener">
                  <h3 class="paper-title">{paper.title}</h3>
                </a>
              ) : (
                <h3 class="paper-title">{paper.title}</h3>
              )}
              <p class="paper-authors">{paper.authors}</p>
              <p class="paper-journal">
                <em>{paper.journal}</em> — {paper.volume}
              </p>
            </article>
          ))}
        </div>
      </div>
    </section>
  ))}
</BaseLayout>

<style>
  .category-title {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--black);
  }

  .papers-list {
    display: grid;
    gap: 0;
  }

  .paper-item {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--gray-200);
  }

  .paper-item:last-child {
    border-bottom: none;
  }

  .paper-title {
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0;
    line-height: 1.5;
    margin-bottom: 0.4rem;
  }

  .paper-link {
    text-decoration: none;
  }

  .paper-link:hover .paper-title {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .paper-link:hover {
    opacity: 1;
  }

  .paper-authors {
    font-size: 0.85rem;
    color: var(--gray-600);
    margin-bottom: 0.2rem;
  }

  .paper-journal {
    font-size: 0.85rem;
    color: var(--gray-400);
  }
</style>
