---
// the-collision.astro — Dramatic book page for The Collision
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const chapters = [
  {
    label: 'Introduction',
    title: 'Why this book, now.',
    body: 'The framing that animates the chapters to come — why AI marks a genuinely different inflection in how we think, and why the usual reassurances miss what is actually at stake.',
  },
  {
    label: 'Chapter 01',
    title: 'The Collision',
    body: 'Every prior cognitive tool reshaped human thought at the periphery, but AI is qualitatively different because it participates in the thinking itself across every domain at once — which is why its effects feel simultaneously subtle and seismic.',
  },
  {
    label: 'Chapter 02',
    title: 'AI Gravity',
    body: 'Deep, deliberate thinking is metabolically expensive, so evolution wired us to conserve cognitive effort — which is precisely why an effortless thinking machine exerts a near-gravitational pull we rarely notice, let alone resist.',
  },
  {
    label: 'Chapter 03',
    title: 'Rules for Navigating the Collision',
    body: 'We need a deliberate cognitive discipline for the AI age, built on four principles: value the struggle, value who you are without AI, reinvest the time AI saves in things that stretch you, and use AI as a cognitive trainer rather than an answer engine.',
  },
  {
    label: 'Chapter 04',
    title: 'Deskilling Me Softly',
    body: 'When we outsource cognitive work to AI, the underlying skills quietly atrophy — judgment, pattern recognition, and expertise fade long before we notice, and often only reveal their absence in the moments we most need them.',
  },
  {
    label: 'Chapter 05',
    title: 'Comfort Traps',
    body: 'Convenience is seductive because it disguises formative struggle as unnecessary friction, and the very effort we bypass is what builds memory, understanding, and the neural pathways of thinking itself.',
  },
  {
    label: 'Chapter 06',
    title: 'Controlling the Conversation',
    body: 'AI companions exploit deep social wiring — our hunger for approval, our instinct to project minds onto machines, our willingness to confide — and in doing so they narrow our views, reinforce our errors, and erode our capacity for authentic human connection.',
  },
  {
    label: 'Chapter 07',
    title: 'False Confidence',
    body: 'AI warps three perceptions at once — what is true, how capable we are, and how capable others are — leaving our confidence intact while the perceptual tools that confidence relies on become dangerously unreliable.',
  },
  {
    label: 'Chapter 08',
    title: 'The Myth of the Dream Team',
    body: 'Pairing powerful AI with capable humans does not automatically produce better outcomes; effective partnerships depend less on the caliber of the components than on designs that calibrate trust, sustain vigilance, and force humans to keep thinking.',
  },
  {
    label: 'Chapter 09',
    title: 'The Aristotle Problem',
    body: 'Personalized, dialogic tutoring has long been the gold standard of learning but unreachable at scale; AI could finally democratize it, but only if classrooms and workplaces are deliberately designed so the technology amplifies learning rather than substituting for it.',
  },
  {
    label: 'Chapter 10',
    title: 'The Final Turn',
    body: 'The book ends where you are about to begin. This one stays between the covers — order your copy to see where the argument lands.',
  },
];
---

<BaseLayout title="The Collision — Eric So" description="The Collision — a new book by Eric So, published by Norton." accent="blue">
  <!-- Full-bleed dark hero with floating book cover -->
  <section class="book-hero" data-theme="dark">
    <div class="book-hero-inner">
      <a href="https://www.amazon.com/Collision-What-AI-Does-Us/dp/1324124628" class="book-cover-wrap" target="_blank" rel="noopener">
        <img
          src={`${base}/images/book-cover.jpg`}
          alt="The Collision — book cover"
          loading="eager"
          class="book-cover-img"
        />
      </a>
      <div class="book-hero-text">
        <span class="section-label">New Book</span>
        <h1 class="book-hero-title">The Collision</h1>
        <p class="book-hero-subtitle">What AI Does to Us</p>
        <p class="book-hero-author">Eric So</p>
        <p class="book-hero-publisher">Published by W. W. Norton</p>
        <hr class="book-divider" />
        <p class="book-hero-desc">
          Book description and details coming soon.
        </p>
        <a href="https://www.amazon.com/Collision-What-AI-Does-Us/dp/1324124628" class="book-cta" target="_blank" rel="noopener">
          Order on Amazon →
        </a>
      </div>
    </div>
  </section>

  <section class="chapters-section" data-theme="light">
    <div class="chapters-intro section-inner">
      <span class="section-label">Inside the Book</span>
      <h2 class="chapters-heading">Nine chapters, one argument.</h2>
      <p class="chapters-lede">
        Each chapter takes on a different way AI is reshaping how we
        think, decide, and learn. Scroll through to see what the book
        covers.
      </p>
    </div>
    <ol class="chapters">
      {chapters.map((ch) => (
        <li class="chapter">
          <div class="chapter-inner">
            <span class="chapter-num">{ch.label}</span>
            <h3 class="chapter-title">{ch.title}</h3>
            <p class="chapter-body">{ch.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>

<style>
  .book-hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: var(--black);
    color: var(--white);
    padding: 6rem var(--section-pad-x) 4rem;
    overflow: hidden;
  }

  .book-hero-inner {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .book-cover-wrap {
    display: flex;
    justify-content: center;
    perspective: 800px;
  }

  .book-cover-img {
    max-width: 520px;
    width: 100%;
    height: auto;
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.5),
      0 0 80px rgba(163, 31, 52, 0.08);
    transform: rotateY(-6deg) rotateX(2deg);
    transition: transform 0.5s ease, box-shadow 0.5s ease;
  }

  .book-cover-wrap:hover .book-cover-img {
    transform: rotateY(0deg) rotateX(0deg) scale(1.03);
    box-shadow:
      0 30px 80px rgba(0, 0, 0, 0.6),
      0 0 100px rgba(163, 31, 52, 0.12);
  }

  .book-hero-text {
    padding-right: 2rem;
  }

  .book-hero-title {
    font-size: clamp(3.5rem, 7vw, 6rem);
    margin-bottom: 0.75rem;
    line-height: 0.95;
  }

  .book-hero-subtitle {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 400;
    text-transform: uppercase;
    color: #4a7cbf;
    margin-top: -0.25rem;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
  }

  .book-hero-author {
    font-family: var(--font-body);
    font-size: 1.2rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  .book-hero-publisher {
    font-size: 0.9rem;
    color: var(--gray-400);
  }

  .book-divider {
    border: none;
    border-top: 1px solid var(--gray-800);
    margin: 2rem 0;
  }

  .book-hero-desc {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--gray-400);
    margin-bottom: 2.5rem;
    max-width: 45ch;
  }

  .book-cta {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px solid var(--white);
    padding: 0.9rem 2rem;
    color: var(--white);
    transition: background-color 0.2s, color 0.2s;
  }

  .book-cta:hover {
    background: var(--white);
    color: var(--black);
    opacity: 1;
  }

  .related-description {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--gray-600);
    max-width: 60ch;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .book-hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .book-cover-img {
      max-width: 260px;
      transform: none;
    }

    .book-hero-text {
      padding: 0;
    }
  }

  /* --- Chapter scrollytelling --- */
  .chapters-section {
    background: var(--pure-white);
    color: var(--black);
    padding: 6rem 0 2rem;
  }

  .chapters-intro {
    max-width: 900px;
    margin: 0 auto 3rem;
    padding-left: var(--section-pad-x);
    padding-right: var(--section-pad-x);
  }

  .chapters-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.02;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .chapters-lede {
    color: var(--gray-600);
    font-size: 1.05rem;
    line-height: 1.65;
    max-width: 60ch;
  }

  .chapters {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 var(--section-pad-x);
    list-style: none;
    counter-reset: chapter;
  }

  .chapter {
    padding: 4.5rem 0;
    border-top: 1px solid var(--gray-200);
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .chapter:last-child {
    border-bottom: 1px solid var(--gray-200);
  }

  .chapter.is-visible {
    opacity: 1;
    transform: none;
  }

  .chapter-num {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .chapter-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    line-height: 1.05;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .chapter-body {
    font-size: 1.1rem;
    line-height: 1.65;
    color: var(--gray-800);
  }

  @media (prefers-reduced-motion: reduce) {
    .chapter {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script is:inline data-astro-rerun>
  // Fade each chapter in as the reader scrolls it into view.
  (function () {
    const chapters = document.querySelectorAll('.chapter');
    if (!chapters.length) return;
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { rootMargin: '0px 0px -15% 0px', threshold: 0.15 }
    );
    chapters.forEach((c) => io.observe(c));
  })();
</script>
