---

<BaseLayout title="Media + Videos — Eric So" description="Media appearances, talks, and video content featuring Eric So." accent="maroon">
  <PageHeader label="Media" title="Media + Videos" image="/images/backdrops/BlurredBackground.jpg" />

  <section class="section" data-theme="light">
    <div class="section-inner">
      <h2 class="media-heading">Videos</h2>
      <div class="video-grid">
        {videos.map((video) => (
          <div class="video-card">
            <div class="video-embed">
              {video.thumb ? (
                <button type="button" class="video-facade" data-yt-id={video.id} data-fit={video.thumbFit ?? 'cover'} aria-label={`Play: ${video.title}`}>
                  <img src={video.thumb} alt="" loading="lazy" />
                  <span class="play-overlay" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="64" height="64"><path d="M8 5v14l11-7z" fill="currentColor"/></svg>
                  </span>
                </button>
              ) : (
                <iframe
                  src={`https://www.youtube.com/embed/${video.id}${video.start ? `?start=${video.start}` : ''}`}
                  title={video.title}
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                ></iframe>
              )}
            </div>
            <p class="video-title">{video.title}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" data-theme="dark">
    <div class="section-inner">
      <h2 class="media-heading">Press &amp; Features</h2>
      <div class="press-grid">
        {press.map((item) => (
          <a href={item.link} class="press-card" target="_blank" rel="noopener">
            <span class="press-source">{item.source}</span>
            <span class="press-title">{item.title}</span>
            <span class="press-cta">Read →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .media-heading {
    margin-bottom: 2.5rem;
  }

  /* Video grid */
  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2rem;
  }

  .video-embed {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    background: var(--gray-800);
  }

  .video-embed iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* Lite-YouTube facade: shows a custom poster until the user clicks play */
  .video-facade {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    padding: 0;
    margin: 0;
    border: none;
    background: var(--gray-800);
    cursor: pointer;
    overflow: hidden;
    display: block;
  }

  .video-facade img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .video-facade[data-fit="contain"] img {
    object-fit: contain;
    background: var(--black);
  }

  .play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.95);
    background: rgba(0, 0, 0, 0.18);
    transition: background-color 0.2s ease;
  }

  .video-facade:hover .play-overlay,
  .video-facade:focus-visible .play-overlay {
    background: rgba(0, 0, 0, 0.32);
  }

  .video-facade:focus-visible {
    outline: none;
  }

  .play-overlay svg {
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.45));
    transition: transform 0.2s ease;
  }

  .video-facade:hover .play-overlay svg,
  .video-facade:focus-visible .play-overlay svg {
    transform: scale(1.08);
  }

  .video-title {
    font-size: 0.85rem;
    font-weight: 500;
    margin-top: 0.75rem;
    color: var(--gray-600);
  }

  /* Press grid */
  .press-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .press-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.75rem;
    border: 1px solid var(--gray-800);
    min-height: 200px;
    transition: background-color 0.2s, border-color 0.2s, transform 0.2s;
  }

  .press-card:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.3);
    transform: translateY(-2px);
    opacity: 1;
  }

  .press-source {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gray-500);
    margin-bottom: 1rem;
  }

  .press-title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.5;
    color: var(--white);
    flex: 1;
  }

  .press-cta {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray-500);
    margin-top: 1.25rem;
    transition: color 0.2s;
  }

  .press-card:hover .press-cta {
    color: var(--white);
  }

  @media (max-width: 1024px) {
    .press-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .video-grid {
      grid-template-columns: 1fr;
    }

    .press-grid {
      grid-template-columns: 1fr;
    }

    .press-card {
      min-height: auto;
    }
  }
</style>

<script>
  function setupVideoFacades() {
    document.querySelectorAll<HTMLButtonElement>('.video-facade').forEach((btn) => {
      btn.onclick = () => {
        const id = btn.dataset.ytId;
        if (!id) return;
        const title = btn.getAttribute('aria-label')?.replace(/^Play:\s*/, '') ?? '';
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1`;
        iframe.title = title;
        iframe.setAttribute('frameborder', '0');
        iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
        iframe.setAttribute('allowfullscreen', '');
        btn.replaceWith(iframe);
      };
    });
  }
  setupVideoFacades();
  document.addEventListener('astro:page-load', setupVideoFacades);
</script>
