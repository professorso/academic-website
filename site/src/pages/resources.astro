---
// resources.astro — Resources page: recommended books, datasets, AI/education links
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import StreamingIntro from '../components/StreamingIntro.astro';

// Books Eric recommends. `featured: true` gets a highlighted "Favorite" badge.
// Cover images resolve from OpenLibrary via ISBN-13; if a cover 404s the tile
// falls back to a dark typographic card. Links go to an Amazon search so we
// never have to track ASINs.
const recommendedBooks = [
  { title: 'Thinking, Fast and Slow', author: 'Daniel Kahneman', isbn: '9780374533557', featured: true },
  { title: 'Nudge: The Final Edition', author: 'Richard H. Thaler and Cass R. Sunstein', isbn: '9780143137009' },
  { title: 'Misbehaving: The Making of Behavioral Economics', author: 'Richard H. Thaler', isbn: '9780393352795' },
  { title: 'Irrational Exuberance (Revised and Expanded Third Edition)', author: 'Robert J. Shiller', isbn: '9780691166261' },
  { title: 'Narrative Economics', author: 'Robert J. Shiller', isbn: '9780691182292' },
  { title: 'Adaptive Markets: Financial Evolution at the Speed of Thought', author: 'Andrew W. Lo', isbn: '9780691191362' },
  { title: 'Efficiently Inefficient: How Smart Money Invests and Market Prices Are Determined', author: 'Lasse Heje Pedersen', isbn: '9780691166193', localCover: 'efficiently-inefficient.jpg' },
  { title: 'Alphanomics: The Informational Underpinnings of Market Efficiency', author: 'Charles M. C. Lee and Eric C. So', isbn: '9781601988928', localCover: 'alphanomics.jpg' },
  { title: 'The Signal and the Noise', author: 'Nate Silver', isbn: '9780143125082' },
  { title: 'Everybody Lies', author: 'Seth Stephens-Davidowitz', isbn: '9780062390868' },
  { title: "Don't Trust Your Gut", author: 'Seth Stephens-Davidowitz', isbn: '9780062880918', coverId: 14695616 },
  { title: 'Outliers: The Story of Success', author: 'Malcolm Gladwell', isbn: '9780316017930' },
  { title: 'Nexus: A Brief History of Information Networks from the Stone Age to AI', author: 'Yuval Noah Harari', isbn: '9780593734223' },
  { title: 'Co-Intelligence: Living and Working with AI', author: 'Ethan Mollick', isbn: '9780593716717', coverId: 14805433 },
  { title: 'Power and Progress: Our Thousand-Year Struggle Over Technology and Prosperity', author: 'Daron Acemoglu and Simon Johnson', isbn: '9781541702530' },
  { title: 'Duped: Truth-Default Theory and the Social Science of Lying and Deception', author: 'Timothy R. Levine', isbn: '9780817320614', coverId: 13547149 },
  { title: 'Designing Your Life: How to Build a Well-Lived, Joyful Life', author: 'Bill Burnett and Dave Evans', isbn: '9781101875322' },
];

function amazonUrl(title: string, author: string) {
  const query = encodeURIComponent(`${title} ${author}`);
  return `https://www.amazon.com/s?k=${query}&i=stripbooks`;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
function coverUrl(book: { isbn: string; coverId?: number; localCover?: string }) {
  if (book.localCover) return `${base}/images/books/${book.localCover}`;
  if (book.coverId) return `https://covers.openlibrary.org/b/id/${book.coverId}-L.jpg?default=false`;
  return `https://covers.openlibrary.org/b/isbn/${book.isbn}-L.jpg?default=false`;
}

const datasets = [
  {
    name: 'Implied Cost of Capital & Expected Return Data',
    paper: 'Lee, Wang, So — Review of Financial Studies',
    link: 'https://leesowang2021.github.io/data/',
    details: '',
    format: 'WEB',
  },
  {
    name: 'Expectations Management Incentive (EMI)',
    paper: 'Johnson, Kim, So — Review of Financial Studies',
    link: 'https://www.dropbox.com/s/kc7u4gowjkggdgk/EMI_RFS.csv?dl=0',
    details: '1985–2015 · Permno, Expected_ann_date, EMI',
    format: 'CSV',
  },
  {
    name: 'Daily Information Asymmetry Proxy (MIA)',
    paper: 'Johnson, So — Management Science',
    link: 'https://www.dropbox.com/s/4hlqlws7dqs8c5o/miadata1996to2018.sas7bdat?dl=0',
    details: '2006–2018 · Permno, Date, MIA',
    format: 'SAS',
  },
];

const edTechResources = [
  {
    name: 'Deep Research: Transforming the Creation of Learning Materials with Research-Backed AI',
    source: 'MIT Sloan EdTech',
    link: 'https://mitsloanedtech.mit.edu/2025/03/26/deep-research-transforming-the-creation-of-learning-materials-with-research-backed-ai/',
  },
  {
    name: 'Timely Insights: Use Cases for OpenAI in the Classroom — DALL-E Imagery and ChatGPT\'s Image Analysis & Voice Functionality',
    source: 'MIT Sloan EdTech',
    link: 'https://mitsloanedtech.mit.edu/2023/10/20/timely-insights-use-cases-for-openai-in-the-classroom-dalle-imagery-and-chatgpts-image-analysis-voice-functionality/',
  },
  {
    name: 'Harnessing AI in Finance: Eric So\'s Innovative Take on Teaching Value Investing',
    source: 'MIT Sloan EdTech',
    link: 'https://mitsloanedtech.mit.edu/2023/09/01/harnessing-ai-in-finance-eric-sos-innovative-take-on-teaching-value-investing/',
  },
  {
    name: 'Sloan Generative AI Peer Learning Initiative',
    source: 'MIT Registrar — Education Initiatives',
    link: 'https://registrar.mit.edu/faculty-curriculum-support/education-initiatives-funding/funded-projects/sloan-generative-ai-peer',
  },
];
---

<BaseLayout title="Resources — Eric So" description="Reading on AI, finance, and teaching, plus research datasets shared by Eric So." accent="grey">
  <PageHeader label="Reading + Data" title="Resources" image="/images/backdrops/Sloan2.jpeg" />

  <section class="section intro-section" data-theme="dark">
    <div class="section-inner">
      <StreamingIntro />
    </div>
  </section>

  <section class="section" data-theme="light">
    <div class="section-inner">
      <h2 class="data-heading">Recommended Books</h2>
      <div class="books-grid">
        {recommendedBooks.map((book) => (
          <a href={amazonUrl(book.title, book.author)} class={`book-card${book.featured ? ' featured' : ''}`} target="_blank" rel="noopener">
            {book.featured && <span class="book-badge">Favorite</span>}
            <div class="book-cover">
              <img
                src={coverUrl(book)}
                alt=""
                loading="lazy"
                onerror="this.remove()"
              />
              <span class="book-cover-fallback">
                <span class="fallback-title">{book.title}</span>
                <span class="fallback-author">{book.author}</span>
              </span>
            </div>
            <div class="book-meta">
              <h3 class="book-title">{book.title}</h3>
              <p class="book-author">{book.author}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" data-theme="dark">
    <div class="section-inner">
      <h2 class="data-heading">Datasets</h2>
      <div class="data-list">
        {datasets.map((ds) => (
          <a href={ds.link} class="data-card" target="_blank" rel="noopener">
            <span class={`file-badge badge-${ds.format.toLowerCase()}`}>{ds.format}</span>
            <div class="data-info">
              <h3 class="data-name">{ds.name}</h3>
              <p class="data-paper">{ds.paper}</p>
              {ds.details && <p class="data-details">{ds.details}</p>}
            </div>
            <span class="data-arrow">→</span>
          </a>
        ))}
      </div>
      <p class="disclaimer">
        Some of these datasets and code artifacts may not be perfectly
        accurate due to ongoing updates to underlying libraries,
        infrastructure, and third-party data providers (for example, WRDS
        occasionally revises historical records when discrepancies are
        identified). Please treat these files as references that may
        require updating or correction. Use at your own risk.
      </p>
    </div>
  </section>

  <section class="section" data-theme="light">
    <div class="section-inner">
      <h2 class="data-heading">AI &amp; Education</h2>
      <div class="edtech-grid">
        {edTechResources.map((res) => (
          <a href={res.link} class="edtech-card" target="_blank" rel="noopener">
            <span class="edtech-source">{res.source}</span>
            <h3 class="edtech-title">{res.name}</h3>
            <span class="edtech-cta">Read More →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .data-heading {
    margin-bottom: 2.5rem;
  }

  /* Recommended Books grid */
  .books-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.75rem 1.25rem;
  }

  .book-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease;
  }

  .book-card:hover {
    transform: translateY(-3px);
    opacity: 1;
  }

  .book-card.featured {
    grid-column: span 2;
    grid-row: span 2;
  }

  .book-cover {
    position: relative;
    aspect-ratio: 2 / 3;
    background: linear-gradient(140deg, #1a1a1a 0%, #2a2a2a 100%);
    overflow: hidden;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.12);
    transition: box-shadow 0.25s ease;
  }

  .book-card:hover .book-cover {
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.22);
  }

  .book-cover img {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .book-cover-fallback {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.6rem;
    padding: 1.25rem;
    text-align: center;
    color: #f2f2f2;
  }

  .fallback-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    line-height: 1.15;
  }

  .fallback-author {
    font-size: 0.75rem;
    color: #9a9a9a;
    letter-spacing: 0.02em;
  }

  .book-badge {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    z-index: 3;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.3rem 0.55rem;
    background: #a31f34;
    color: #fff;
  }

  .book-meta {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .book-title {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0;
    line-height: 1.35;
    margin: 0;
  }

  .book-author {
    font-size: 0.8rem;
    color: var(--gray-600);
    margin: 0;
  }

  .book-card.featured .book-title {
    font-size: 1.05rem;
    line-height: 1.3;
  }

  .book-card.featured .book-author {
    font-size: 0.85rem;
  }

  @media (max-width: 1000px) {
    .books-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 760px) {
    .books-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .book-card.featured {
      grid-row: auto;
    }
  }

  @media (max-width: 500px) {
    .books-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem 1rem;
    }
    .book-card.featured {
      grid-column: span 2;
    }
  }

  .intro-section {
    padding-top: clamp(1.5rem, 4vw, 3rem);
    padding-bottom: clamp(1.5rem, 4vw, 3rem);
  }

  .data-list {
    display: grid;
    gap: 0;
  }

  .data-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--gray-200);
    transition: padding-left 0.2s ease;
  }

  .section[data-theme="dark"] .data-card {
    border-color: var(--gray-800);
  }

  .data-card:first-child {
    border-top: 1px solid var(--gray-200);
  }

  .section[data-theme="dark"] .data-card:first-child {
    border-top-color: var(--gray-800);
  }

  .data-card:hover {
    padding-left: 1rem;
    opacity: 1;
  }

  .data-name {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0;
    line-height: 1.4;
    margin-bottom: 0.3rem;
  }

  .data-paper {
    font-size: 0.85rem;
    color: var(--gray-600);
    margin-bottom: 0.2rem;
  }

  .section[data-theme="dark"] .data-paper {
    color: var(--gray-400);
  }

  .data-info {
    flex: 1;
    min-width: 0;
  }

  .data-details {
    font-size: 0.8rem;
    color: var(--gray-400);
    font-family: monospace;
  }

  /* File type badges */
  .file-badge {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: 6px;
  }

  .badge-csv {
    background: rgba(76, 175, 80, 0.12);
    color: #4caf50;
    border: 1px solid rgba(76, 175, 80, 0.3);
  }

  .badge-sas {
    background: rgba(50, 120, 210, 0.12);
    color: #3278d2;
    border: 1px solid rgba(50, 120, 210, 0.3);
  }

  .badge-web {
    background: rgba(140, 140, 140, 0.1);
    color: #888;
    border: 1px solid rgba(140, 140, 140, 0.3);
  }

  .badge-link {
    background: rgba(163, 31, 52, 0.12);
    color: #a31f34;
    border: 1px solid rgba(163, 31, 52, 0.3);
  }

  /* Dark theme badge adjustments */
  .section[data-theme="dark"] .badge-csv {
    background: rgba(76, 175, 80, 0.15);
  }
  .section[data-theme="dark"] .badge-sas {
    background: rgba(50, 120, 210, 0.15);
  }
  .section[data-theme="dark"] .badge-link {
    background: rgba(163, 31, 52, 0.2);
    color: #e05a6f;
  }

  .data-arrow {
    font-size: 1.2rem;
    opacity: 0;
    transition: opacity 0.2s;
    flex-shrink: 0;
    margin-top: 0.2rem;
  }

  .data-card:hover .data-arrow {
    opacity: 1;
  }

  /* AI & Education grid cards (light-theme section) */
  .edtech-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .edtech-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.25rem;
    padding: 1.75rem;
    background: var(--pure-white);
    border: 1px solid var(--gray-200);
    border-left: 3px solid var(--accent);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    transition: background-color 0.2s, border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    min-height: 200px;
  }

  .edtech-card:hover {
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
    opacity: 1;
  }

  .edtech-source {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
  }

  .edtech-title {
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0;
    line-height: 1.5;
    color: var(--black);
  }

  .edtech-cta {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray-600);
    transition: color 0.2s;
  }

  .edtech-card:hover .edtech-cta {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .edtech-grid {
      grid-template-columns: 1fr;
    }

    .edtech-card {
      padding: 1.5rem;
      min-height: auto;
    }
  }

  .disclaimer {
    margin-top: 2.5rem;
    font-size: 0.85rem;
    color: var(--gray-500);
    font-style: italic;
    max-width: 60ch;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .data-arrow {
      display: none;
    }
  }
</style>
