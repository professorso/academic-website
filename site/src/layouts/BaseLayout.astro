---
// BaseLayout.astro — HTML shell with fonts, nav, footer, contact modal
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import ContactModal from '../components/ContactModal.astro';
import CommandPalette from '../components/CommandPalette.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Eric So — MIT Sloan',
  description = 'Eric C. So is the Sloan Distinguished Professor of Global Economics and Behavioral Science at MIT Sloan School of Management. Research on financial markets, investor behavior, and AI in finance and education.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonical = `${siteUrl}${Astro.url.pathname}`;

// Map the current pathname to its matching OG image.
// Pages live at /<slug>/ (e.g. /research/), root is 'index'.
const ogSlug = (() => {
  const p = Astro.url.pathname.replace(/^\/+|\/+$/g, '');
  return p === '' ? 'index' : p;
})();
const ogImage = `${siteUrl}${base}/og/${ogSlug}.png`;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Eric C. So',
  jobTitle: 'Sloan Distinguished Professor of Global Economics and Behavioral Science',
  affiliation: {
    '@type': 'CollegeOrUniversity',
    name: 'MIT Sloan School of Management',
    url: 'https://mitsloan.mit.edu',
  },
  url: siteUrl || 'https://ericso.pro',
  sameAs: [
    'https://www.linkedin.com/in/eric-so-87531768/',
    'https://papers.ssrn.com/sol3/cf_dev/AbsByAuth.cfm?per_id=1431328',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    <!-- Person schema for Google Knowledge Graph -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <Navbar />
    <ContactModal />
    <CommandPalette />

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer section" data-theme="dark">
      <div class="section-inner footer-inner">
        <span class="footer-logo">ERIC SO</span>
        <p class="footer-text">MIT Sloan School of Management</p>
        <p class="footer-text footer-small">100 Main St, Cambridge, MA 02142</p>
        <div class="footer-links">
          <a href={`${base}/now/`} class="footer-text footer-small footer-link">Now</a>
          <span class="footer-sep" aria-hidden="true">·</span>
          <a href={`${base}/accessibility/`} class="footer-text footer-small footer-link">Accessibility</a>
        </div>
      </div>
    </footer>

    <script is:inline data-astro-rerun src={`${base}/scripts/scroll-inversion.js`}></script>
    <script is:inline data-astro-rerun src={`${base}/scripts/particles.js`}></script>
  </body>
</html>

<style>
  .site-footer {
    padding: 3rem var(--section-pad-x);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }

  .footer-text {
    font-size: 0.85rem;
    color: var(--gray-400);
    margin-bottom: 0;
  }

  .footer-small {
    font-size: 0.75rem;
  }

  .footer-links {
    margin-top: 0.75rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .footer-sep {
    color: var(--gray-500, #888);
    font-size: 0.75rem;
  }

  .footer-link {
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s;
  }

  .footer-link:hover {
    opacity: 0.6;
  }
</style>
